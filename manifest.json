{
  "manifest_version": 3,
  "name": "Auto YT Audio Downloader",
  "version": "0.1.0",
  "description": "Baixa automaticamente áudio do YouTube usando Shira",
  "icons": {
    "16": "icon/icon16.png",
    "32": "icon/icon32.png",
    "48": "icon/icon48.png",
    "128": "icon/icon128.png"
  },

  "permissions": [
    "storage", 
    "nativeMessaging"
  ],

  "host_permissions": [
    "*://www.youtube.com/*"
  ],

  "action": {
    "default_title": "Dafne",
    "default_icon": {
      "16": "icon/icon16.png",
      "32": "icon/icon32.png",
      "48": "icon/icon48.png",
      "128": "icon/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"

  },

  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}
